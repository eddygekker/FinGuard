FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000
# Leave unset to use data/finguard.db
# DATABASE_PATH=

# Copilot provider: local (no key), groq, gemini, or openai
LLM_PROVIDER=local

# Groq (free key: https://console.groq.com)
# LLM_PROVIDER=groq
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (key must start with AIza: https://aistudio.google.com/apikey)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
